<mxfile host="Electron">
  <diagram id="fig01-architecture-landscape" name="Figure 1. Architecture Landscape">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="label-title" value="Figure 1. Architectural routes from long context to state-centric serving" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=20;fontColor=#0F172A;" vertex="1" parent="1">
          <mxGeometry x="56" y="30" width="1400" height="28" as="geometry" />
        </mxCell>
        <mxCell id="label-sub" value="Observed system pressure, current open-model responses, and the hypothesized Linear-first end-state" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="56" y="62" width="1400" height="22" as="geometry" />
        </mxCell>
        <mxCell id="group-1" value="OBSERVED PRESSURE" style="text;html=1;strokeColor=#94A3B8;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=3;dashed=1;dashPattern=8 6;fontSize=13;fontStyle=1;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="72" y="100" width="1440" height="240" as="geometry" />
        </mxCell>
        <mxCell id="group-2" value="COMPETING RESPONSES" style="text;html=1;strokeColor=#94A3B8;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=3;dashed=1;dashPattern=8 6;fontSize=13;fontStyle=1;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="72" y="370" width="1440" height="360" as="geometry" />
        </mxCell>
        <mxCell id="node-1" value="&lt;b&gt;System bottleneck&lt;/b&gt;&lt;br&gt;KV cache grows with context length&lt;br&gt;prefill/decode bandwidth couples serving&lt;br&gt;agent workloads → time-horizon cost" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="142" width="360" height="156" as="geometry" />
        </mxCell>
        <mxCell id="node-2" value="&lt;b&gt;Market signal&lt;/b&gt;&lt;br&gt;Products advertising longer service duration&lt;br&gt;not just larger context windows&lt;br&gt;planning + tool use + continuity matter more" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="142" width="420" height="156" as="geometry" />
        </mxCell>
        <mxCell id="node-3" value="&lt;b&gt;Research question&lt;/b&gt;&lt;br&gt;When service length T → ∞, should memory remain token-addressable, or become state-preserving and externally recallable?" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=13;fillColor=#DBEAFE;strokeColor=#2563EB;fontStyle=1;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="1020" y="142" width="420" height="156" as="geometry" />
        </mxCell>
        <mxCell id="node-4" value="&lt;b&gt;Full attention&lt;/b&gt;&lt;br&gt;strong exact token recall&lt;br&gt;best-understood infrastructure&lt;br&gt;memory and bandwidth scale with history" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="426" width="300" height="200" as="geometry" />
        </mxCell>
        <mxCell id="node-5" value="&lt;b&gt;Hybrid&lt;/b&gt;&lt;br&gt;Qwen3.6 / Kimi Linear / OLMo Hybrid&lt;br&gt;replace most layers with recurrent or linear state&lt;br&gt;retain attention as a precision backstop" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="470" y="426" width="300" height="200" as="geometry" />
        </mxCell>
        <mxCell id="node-6" value="&lt;b&gt;Sparse / MLA / SWA&lt;/b&gt;&lt;br&gt;DeepSeek-V2/V3.x / GLM / sliding-window stacks&lt;br&gt;compress or localize attention coverage&lt;br&gt;token-level addressing with better efficiency" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="426" width="300" height="200" as="geometry" />
        </mxCell>
        <mxCell id="node-7" value="&lt;b&gt;Linear-first agent stack&lt;/b&gt;&lt;br&gt;bounded live state&lt;br&gt;retrieval-triggered external recall&lt;br&gt;persistent memory + tools + compaction" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=13;fillColor=#DBEAFE;strokeColor=#2563EB;fontStyle=1;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="1170" y="426" width="300" height="200" as="geometry" />
        </mxCell>
        <mxCell id="node-8" value="&lt;b&gt;Thesis&lt;/b&gt;&lt;br&gt;The endgame of long context is not a bigger window; it is a longer, state-centric service horizon." style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#ECFDF5;strokeColor=#0F766E;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="778" width="800" height="80" as="geometry" />
        </mxCell>
        <mxCell id="edge-1" value="baseline" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#475569;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;" edge="1" source="node-1" target="node-4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-2" value="reduce slope" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1D4ED8;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;" edge="1" source="node-2" target="node-5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-3" value="compress cost" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#0F766E;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;" edge="1" source="node-2" target="node-6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-4" value="time-horizon shift" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#7C3AED;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;" edge="1" source="node-3" target="node-7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-5" value="thesis" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#0F766E;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;" edge="1" source="node-7" target="node-8" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="label-footnote" value="Observed evidence: model cards, serving papers, and product docs. The Linear-first end-state is a forward-looking synthesis rather than an announced industry consensus." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="56" y="910" width="1200" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
