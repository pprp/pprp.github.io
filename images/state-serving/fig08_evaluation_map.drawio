<mxfile host="Electron">
  <diagram id="fig08-evaluation-map" name="Figure 8. Evaluation Map">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="label-title" value="Figure 8. Evaluation map for state-centric serving" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=20;fontColor=#0F172A;" vertex="1" parent="1">
          <mxGeometry x="56" y="30" width="1400" height="28" as="geometry" />
        </mxCell>
        <mxCell id="label-sub" value="Long service requires measuring more than perplexity or window length: memory, tool-use, compaction, and recovery all matter" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="56" y="62" width="1450" height="22" as="geometry" />
        </mxCell>
        <mxCell id="group-1" value="BENCHMARKS AND MISSING METRICS" style="text;html=1;strokeColor=#94A3B8;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=3;dashed=1;dashPattern=8 6;fontSize=13;fontStyle=1;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="70" y="100" width="1460" height="720" as="geometry" />
        </mxCell>
        <mxCell id="node-1" value="&lt;b&gt;LoCoMo&lt;/b&gt;&lt;br&gt;300-turn, multi-session benchmark&lt;br&gt;Temporal + causal memory" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="162" width="290" height="110" as="geometry" />
        </mxCell>
        <mxCell id="node-2" value="&lt;b&gt;LongMemEval&lt;/b&gt;&lt;br&gt;500 QA over sustained chats&lt;br&gt;Extraction + reasoning + updates" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="316" width="290" height="110" as="geometry" />
        </mxCell>
        <mxCell id="node-3" value="&lt;b&gt;BEAM&lt;/b&gt;&lt;br&gt;Up to 10M tokens&lt;br&gt;Memory at ultra-long scale" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="470" width="290" height="110" as="geometry" />
        </mxCell>
        <mxCell id="node-4" value="&lt;b&gt;MCP-Atlas / tool benchmarks&lt;/b&gt;&lt;br&gt;36 real servers, 220 tools&lt;br&gt;Realistic tool orchestration" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="624" width="290" height="110" as="geometry" />
        </mxCell>
        <mxCell id="node-5" value="&lt;b&gt;What current benchmarks mostly cover&lt;/b&gt;&lt;br&gt;1. Recall from long histories&lt;br&gt;2. Multi-session temporal reasoning&lt;br&gt;3. Knowledge updates and contradictions&lt;br&gt;4. Tool-use planning in realistic workflows" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=13;fillColor=#DBEAFE;strokeColor=#2563EB;fontStyle=1;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="162" width="420" height="572" as="geometry" />
        </mxCell>
        <mxCell id="node-6" value="&lt;b&gt;What a state-serving benchmark should add&lt;/b&gt;&lt;br&gt;1. State carry-over rate after compaction&lt;br&gt;2. Retrieval-trigger precision / recall&lt;br&gt;3. Memory write amplification and token overhead&lt;br&gt;4. Error-recovery half-life after tool failure&lt;br&gt;5. Cross-session identity continuity under new evidence&lt;br&gt;6. Privacy and policy isolation of portable state" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=13;fillColor=#FFF1F2;strokeColor=#BE123C;fontStyle=1;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="1010" y="162" width="440" height="572" as="geometry" />
        </mxCell>
        <mxCell id="edge-1" value="memory" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1D4ED8;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" source="node-1" target="node-5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-2" value="interactive" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#0F766E;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.45;entryDx=0;entryDy=0;" edge="1" source="node-2" target="node-5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-3" value="scale" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#B45309;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.6;entryDx=0;entryDy=0;" edge="1" source="node-3" target="node-5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-4" value="tool use" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#7C3AED;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;" edge="1" source="node-4" target="node-5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-5" value="missing metrics" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#BE123C;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="node-5" target="node-6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="label-footnote" value="A state-centric system should be judged by what survives the next service window, not only by what fits inside the current one." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#64748B;" vertex="1" parent="1">
