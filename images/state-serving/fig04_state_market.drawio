<mxfile host="Electron">
  <diagram id="fig04-state-market" name="Figure 4. State Artifact Economy">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="label-title" value="Figure 4. From reusable state to a possible state-artifact economy" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=20;fontColor=#0F172A;" vertex="1" parent="1">
          <mxGeometry x="90" y="30" width="1400" height="28" as="geometry" />
        </mxCell>
        <mxCell id="label-sub" value="What could become portable is not an arbitrary prompt, but a compatibility-checked state object with provenance and policy metadata" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="90" y="62" width="1450" height="22" as="geometry" />
        </mxCell>
        <mxCell id="group-1" value="ARTIFACT LIFECYCLE" style="text;html=1;strokeColor=#94A3B8;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=3;dashed=1;dashPattern=8 6;fontSize=13;fontStyle=1;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="90" y="100" width="1420" height="360" as="geometry" />
        </mxCell>
        <mxCell id="group-2" value="WHAT REMAINS SPECULATIVE" style="text;html=1;strokeColor=#94A3B8;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;arcSize=3;dashed=1;dashPattern=8 6;fontSize=13;fontStyle=1;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="84" y="490" width="1420" height="200" as="geometry" />
        </mxCell>
        <mxCell id="node-1" value="&lt;b&gt;Mint&lt;/b&gt;&lt;br&gt;Prefill or initialize a task-specific state&lt;br&gt;Bind model hash, tokenizer, tools, safety policy" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="130" y="160" width="270" height="130" as="geometry" />
        </mxCell>
        <mxCell id="node-2" value="&lt;b&gt;State artifact&lt;/b&gt;&lt;br&gt;prefix / context fingerprint&lt;br&gt;compatible model family&lt;br&gt;task schema + persona tag&lt;br&gt;active-horizon assumptions&lt;br&gt;provenance + version history" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=13;fillColor=#DBEAFE;strokeColor=#2563EB;fontStyle=1;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="470" y="140" width="320" height="260" as="geometry" />
        </mxCell>
        <mxCell id="node-3" value="&lt;b&gt;Verify&lt;/b&gt;&lt;br&gt;Compatibility, provenance, safety" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="150" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="node-4" value="&lt;b&gt;Compose&lt;/b&gt;&lt;br&gt;Merge with workflow state or org memory" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="290" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="node-5" value="&lt;b&gt;Execute&lt;/b&gt;&lt;br&gt;Resume agent loop with tools and retrieval" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#ECFDF5;strokeColor=#0F766E;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="1180" y="150" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="node-6" value="&lt;b&gt;Settle&lt;/b&gt;&lt;br&gt;Price usage, track value, log outcomes" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#EFF6FF;strokeColor=#94A3B8;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="1180" y="290" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="node-7" value="&lt;b&gt;Important caveat&lt;/b&gt;&lt;br&gt;This is an inference from serving constraints and memory-system design, not a current market standard." style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.5;fontSize=13;fillColor=#FEF3C7;strokeColor=#B45309;fontColor=#0F172A;spacing=10;spacingTop=8;spacingBottom=8;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="144" y="534" width="1320" height="112" as="geometry" />
        </mxCell>
        <mxCell id="edge-1" value="create" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1D4ED8;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="node-1" target="node-2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-2" value="check" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#0F766E;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="node-2" target="node-3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-3" value="merge" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#7C3AED;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="node-2" target="node-4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-4" value="load" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1D4ED8;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="node-3" target="node-5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-5" value="price / account" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#B45309;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="node-4" target="node-6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-6" value="outcome log" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#475569;endArrow=blockThin;endFill=1;fontSize=12;fontColor=#475569;" edge="1" source="node-5" target="node-6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="label-legend" value="→ execution path (navy)  ·  → compatibility checks (teal)  ·  → pricing / settlement (amber)  ·  → composition (violet)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="90" y="706" width="800" height="22" as="geometry" />
        </mxCell>
        <mxCell id="label-footnote" value="The artifact metaphor becomes plausible only if memory is explicit, versioned, and cheap to reload relative to re-creating full context." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="90" y="740" width="1400" height="22" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
