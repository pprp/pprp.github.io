  <diagram id="fig03_memory_stack_zh" name="fig03_memory_stack_zh">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="16" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="fig03_memory_stack_zh-title" value="&lt;b&gt;图 3. 面向 state-centric serving 的四层记忆栈&lt;/b&gt;&lt;br/&gt;关键区别不只是短期 / 长期，而是参数记忆、live state、外部记忆与工具校验源" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e2e8f0;strokeWidth=1.5;fontColor=#0f172a;fontSize=18;spacing=10;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="48" y="36" width="1504" height="72" as="geometry" />
        </mxCell>
        <mxCell id="g1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#64748B;strokeWidth=1.5;dashed=1;dashPattern=8 6;" vertex="1" parent="1">
          <mxGeometry x="120" y="152" width="1120" height="640" as="geometry" />
        </mxCell>
        <mxCell id="g1-label" value="&lt;b&gt;记忆层级&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#64748B;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="136" y="130" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n1" value="&lt;b&gt;快 / 稀缺&lt;/b&gt;&lt;br/&gt;高价值状态&lt;br/&gt;应留在这里" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#B45309;strokeWidth=1.5;fontColor=#0F172A;fontSize=14;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1320" y="214" width="210" height="108" as="geometry" />
        </mxCell>
        <mxCell id="n1-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B45309;strokeColor=#B45309;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1322" y="216" width="206" height="8" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="&lt;b&gt;慢 / 丰富&lt;/b&gt;&lt;br/&gt;显式保存产物&lt;br/&gt;按需获取" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDFA;strokeColor=#0F766E;strokeWidth=1.5;fontColor=#0F172A;fontSize=14;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1320" y="690" width="210" height="108" as="geometry" />
        </mxCell>
        <mxCell id="n2-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;strokeColor=#0F766E;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1322" y="692" width="206" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="&lt;b&gt;第 1 层. 权重 / 参数记忆&lt;/b&gt;&lt;br/&gt;通用能力、广义先验、模型身份&lt;br/&gt;更新慢、全局共享、个性化成本高" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="208" width="920" height="110" as="geometry" />
        </mxCell>
        <mxCell id="b1-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D4ED8;strokeColor=#1D4ED8;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="222" y="210" width="916" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="&lt;b&gt;第 2 层. Live state / 活跃跨度&lt;/b&gt;&lt;br/&gt;任务计划、当前假设、局部变量、近期工具结果&lt;br/&gt;受质量-成本权衡约束，而不是追求记住一切" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="350" width="920" height="132" as="geometry" />
        </mxCell>
        <mxCell id="b2-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B45309;strokeColor=#B45309;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="222" y="352" width="916" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="&lt;b&gt;第 3 层. 外部记忆产物&lt;/b&gt;&lt;br/&gt;notes、AGENTS.md、memories、plans、检索索引、结构化摘要&lt;br/&gt;可版本化、可检查、可共享，比原始 token 历史更便宜" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="528" width="920" height="132" as="geometry" />
        </mxCell>
        <mxCell id="b3-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;strokeColor=#0F766E;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="222" y="530" width="916" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b4" value="&lt;b&gt;第 4 层. 工具与环境&lt;/b&gt;&lt;br/&gt;repo 状态、数据库、浏览器、API、观测指标、真实系统&lt;br/&gt;当模型必须验证而非仅凭记忆时的最终事实来源" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="706" width="920" height="110" as="geometry" />
        </mxCell>
        <mxCell id="b4-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#7C3AED;strokeWidth=1;" vertex="1" parent="1">
