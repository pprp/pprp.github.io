  <diagram id="fig01_architecture_landscape_zh" name="fig01_architecture_landscape_zh">
    <mxGraphModel dx="1460" dy="921" grid="1" gridSize="16" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="fig01_architecture_landscape_zh-title" value="&lt;b&gt;图 1. 从长上下文到 state-centric serving 的架构路线&lt;/b&gt;&lt;br/&gt;系统压力、开源模型的现实回应，以及假设的 Linear-first 终局" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e2e8f0;strokeWidth=1.5;fontColor=#0f172a;fontSize=18;spacing=10;align=left;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="48" y="36" width="1504" height="72" as="geometry" />
        </mxCell>
        <mxCell id="g1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#64748B;strokeWidth=1.5;dashed=1;dashPattern=8 6;" parent="1" vertex="1">
          <mxGeometry x="72" y="150" width="1440" height="260" as="geometry" />
        </mxCell>
        <mxCell id="g1-label" value="&lt;b&gt;观察到的压力&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#64748B;fontSize=14;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="88" y="128" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1D4ED8;strokeWidth=1.5;dashed=1;dashPattern=8 6;" parent="1" vertex="1">
          <mxGeometry x="72" y="450" width="1440" height="360" as="geometry" />
        </mxCell>
        <mxCell id="g2-label" value="&lt;b&gt;竞争性回应&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#1D4ED8;fontSize=14;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="88" y="428" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="&lt;b&gt;系统瓶颈&lt;/b&gt;&lt;br/&gt;KV cache 随上下文长度增长&lt;br/&gt;prefill/decode 带宽耦合 serving&lt;br/&gt;agent 工作负载把窗口大小转化为时间跨度成本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="120" y="194" width="360" height="164" as="geometry" />
        </mxCell>
        <mxCell id="b1-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B45309;strokeColor=#B45309;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="122" y="196" width="356" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="&lt;b&gt;市场信号&lt;/b&gt;&lt;br/&gt;产品开始宣传更长服务时长&lt;br/&gt;不只是更大上下文窗口&lt;br/&gt;规划 + 工具使用 + 连续性更重要" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="540" y="194" width="420" height="164" as="geometry" />
        </mxCell>
        <mxCell id="b2-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;strokeColor=#0F766E;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="542" y="196" width="416" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="&lt;b&gt;研究问题&lt;/b&gt;&lt;br/&gt;当服务长度 T → ∞，&lt;br/&gt;记忆应继续以 token 寻址，&lt;br/&gt;还是转向保状态并可外部召回？" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="1020" y="194" width="420" height="164" as="geometry" />
        </mxCell>
        <mxCell id="b3-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#7C3AED;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="1022" y="196" width="416" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b4" value="&lt;b&gt;全注意力&lt;/b&gt;&lt;br/&gt;精确 token 回忆强&lt;br/&gt;基础设施最成熟&lt;br/&gt;但内存与带宽随历史增长" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="120" y="508" width="300" height="208" as="geometry" />
        </mxCell>
        <mxCell id="b4-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BE123C;strokeColor=#BE123C;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="138" y="510" width="262" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b5" value="&lt;b&gt;Hybrid&lt;/b&gt;&lt;br/&gt;Qwen3.6 / Kimi Linear / OLMo Hybrid&lt;br/&gt;用 recurrent 或 linear state 替代多数层&lt;br/&gt;保留 attention 作为精度后备" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="470" y="508" width="300" height="208" as="geometry" />
        </mxCell>
        <mxCell id="b5-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D4ED8;strokeColor=#1D4ED8;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="488" y="508" width="264" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b6" value="&lt;b&gt;Sparse / MLA / SWA&lt;/b&gt;&lt;br/&gt;DeepSeek-V2/V3.x / GLM / sliding-window stacks&lt;br/&gt;压缩或局部化 attention 覆盖&lt;br/&gt;以更高效率保留 token 级寻址" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="820" y="508" width="300" height="208" as="geometry" />
        </mxCell>
        <mxCell id="b6-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;strokeColor=#0F766E;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="822" y="510" width="296" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b7" value="&lt;b&gt;Linear-first agent 栈&lt;/b&gt;&lt;br/&gt;有界 live state&lt;br/&gt;由检索触发外部召回&lt;br/&gt;持久记忆 + 工具 + 压缩" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="1170" y="508" width="300" height="208" as="geometry" />
        </mxCell>
        <mxCell id="b7-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#7C3AED;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="1172" y="510" width="296" height="8" as="geometry" />
        </mxCell>
        <mxCell id="b8" value="&lt;b&gt;核心论点&lt;/b&gt;&lt;br/&gt;长上下文的终点不是更大窗口，而是更长的 state-centric 服务周期。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=14;spacingTop=12;spacingLeft=18;spacingRight=18;align=center;verticalAlign=middle;" parent="1" vertex="1">
