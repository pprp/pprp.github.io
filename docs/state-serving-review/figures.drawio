                <mxCell id="fig01_architecture_landscape-foot-1" value="The Linear-first end-state is a forward-looking synthesis rather than an announced industry consensus." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#475569;fontSize=13;" parent="1" vertex="1">
