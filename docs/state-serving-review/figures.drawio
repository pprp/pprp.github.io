<mxfile host="65bd71144e">
    <diagram id="fig01_architecture_landscape" name="fig01_architecture_landscape">
        <mxGraphModel dx="1460" dy="921" grid="1" gridSize="16" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="980" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="fig01_architecture_landscape-title" value="&lt;b&gt;Figure 1. Architectural routes from long context to state-centric serving&lt;/b&gt;&lt;br/&gt;Observed system pressure, current open-model responses, and the hypothesized Linear-first end-state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e2e8f0;strokeWidth=1.5;fontColor=#0f172a;fontSize=18;spacing=10;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="48" y="36" width="1504" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="g1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#64748B;strokeWidth=1.5;dashed=1;dashPattern=8 6;" parent="1" vertex="1">
                    <mxGeometry x="72" y="150" width="1440" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="g1-label" value="&lt;b&gt;OBSERVED PRESSURE&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#64748B;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="88" y="128" width="240" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="g2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1D4ED8;strokeWidth=1.5;dashed=1;dashPattern=8 6;" parent="1" vertex="1">
                    <mxGeometry x="72" y="450" width="1440" height="360" as="geometry"/>
                </mxCell>
                <mxCell id="g2-label" value="&lt;b&gt;COMPETING RESPONSES&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#1D4ED8;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="88" y="428" width="240" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="b1" value="&lt;b&gt;System bottleneck&lt;/b&gt;&lt;br/&gt;KV cache grows with context length&lt;br/&gt;prefill/decode bandwidth couples&lt;br/&gt;serving&lt;br/&gt;agent workloads turn window size&lt;br/&gt;into time-horizon cost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="120" y="194" width="360" height="164" as="geometry"/>
                </mxCell>
                <mxCell id="b1-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B45309;strokeColor=#B45309;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="122" y="196" width="356" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b2" value="&lt;b&gt;Market signal&lt;/b&gt;&lt;br/&gt;products are advertising longer service&lt;br/&gt;duration&lt;br/&gt;not just larger context windows&lt;br/&gt;planning + tool use + continuity matter&lt;br/&gt;more" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="540" y="194" width="420" height="164" as="geometry"/>
                </mxCell>
                <mxCell id="b2-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;strokeColor=#0F766E;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="542" y="196" width="416" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b3" value="&lt;b&gt;Research question&lt;/b&gt;&lt;br/&gt;when service length T → ∞,&lt;br/&gt;should memory remain token-addressable,&lt;br/&gt;or become state-preserving and externally&lt;br/&gt;recallable?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1020" y="194" width="420" height="164" as="geometry"/>
                </mxCell>
                <mxCell id="b3-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#7C3AED;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="1022" y="196" width="416" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b4" value="&lt;b&gt;Full attention&lt;/b&gt;&lt;br/&gt;strong exact token recall&lt;br/&gt;best-understood&lt;br/&gt;infrastructure&lt;br/&gt;but memory and bandwidth&lt;br/&gt;scale with history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="120" y="508" width="300" height="208" as="geometry"/>
                </mxCell>
                <mxCell id="b4-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BE123C;strokeColor=#BE123C;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="138" y="510" width="262" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b5" value="&lt;b&gt;Hybrid&lt;/b&gt;&lt;br/&gt;Qwen3.6 / Kimi Linear / OLMo&lt;br/&gt;Hybrid&lt;br/&gt;replace most layers with&lt;br/&gt;recurrent or linear state&lt;br/&gt;retain attention as a&lt;br/&gt;precision backstop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="470" y="508" width="300" height="208" as="geometry"/>
                </mxCell>
                <mxCell id="b5-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D4ED8;strokeColor=#1D4ED8;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="488" y="508" width="264" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b6" value="&lt;b&gt;Sparse / MLA / SWA&lt;/b&gt;&lt;br/&gt;DeepSeek-V2/V3.x / GLM /&lt;br/&gt;sliding-window stacks&lt;br/&gt;compress or localize&lt;br/&gt;attention coverage&lt;br/&gt;preserve token-level&lt;br/&gt;addressing with better&lt;br/&gt;efficiency" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="820" y="508" width="300" height="208" as="geometry"/>
                </mxCell>
                <mxCell id="b6-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;strokeColor=#0F766E;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="822" y="510" width="296" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b7" value="&lt;b&gt;Linear-first agent&lt;br/&gt;stack&lt;/b&gt;&lt;br/&gt;bounded live state&lt;br/&gt;retrieval-triggered external&lt;br/&gt;recall&lt;br/&gt;persistent memory + tools +&lt;br/&gt;compaction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1170" y="508" width="300" height="208" as="geometry"/>
                </mxCell>
                <mxCell id="b7-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#7C3AED;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="1172" y="510" width="296" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b8" value="&lt;b&gt;Thesis&lt;/b&gt;&lt;br/&gt;The endgame of long context is not a bigger window; it is a longer, state-centric service&lt;br/&gt;horizon." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=14;spacingTop=12;spacingLeft=18;spacingRight=18;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="400" y="834" width="800" height="84" as="geometry"/>
                </mxCell>
                <mxCell id="b8-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B45309;strokeColor=#B45309;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="402" y="836" width="796" height="8" as="geometry"/>
