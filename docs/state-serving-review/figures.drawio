    <diagram id="fig03_memory_stack" name="fig03_memory_stack">
        <mxGraphModel dx="1600" dy="900" grid="1" gridSize="16" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="980" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="fig03_memory_stack-title" value="&lt;b&gt;Figure 3. A four-layer memory stack for state-centric serving&lt;/b&gt;&lt;br/&gt;The useful distinction is not just short-term vs long-term, but parameter memory vs live state vs external memory vs tool-ground truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e2e8f0;strokeWidth=1.5;fontColor=#0f172a;fontSize=18;spacing=10;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="48" y="36" width="1504" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="g1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#64748B;strokeWidth=1.5;dashed=1;dashPattern=8 6;" vertex="1" parent="1">
                    <mxGeometry x="120" y="152" width="1120" height="640" as="geometry"/>
                </mxCell>
                <mxCell id="g1-label" value="&lt;b&gt;MEMORY HIERARCHY&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#64748B;fontSize=14;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="136" y="130" width="240" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="n1" value="&lt;b&gt;Fast / scarce&lt;/b&gt;&lt;br/&gt;high-value state&lt;br/&gt;should stay here" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#B45309;strokeWidth=1.5;fontColor=#0F172A;fontSize=14;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="1320" y="214" width="210" height="108" as="geometry"/>
                </mxCell>
                <mxCell id="n1-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B45309;strokeColor=#B45309;strokeWidth=1;" vertex="1" parent="1">
                    <mxGeometry x="1322" y="216" width="206" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="n2" value="&lt;b&gt;Slow / rich&lt;/b&gt;&lt;br/&gt;store explicit&lt;br/&gt;artifacts and fetch&lt;br/&gt;on demand" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDFA;strokeColor=#0F766E;strokeWidth=1.5;fontColor=#0F172A;fontSize=14;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="1320" y="690" width="210" height="108" as="geometry"/>
                </mxCell>
                <mxCell id="n2-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;strokeColor=#0F766E;strokeWidth=1;" vertex="1" parent="1">
                    <mxGeometry x="1322" y="692" width="206" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b1" value="&lt;b&gt;Layer 1. Weights / parameter memory&lt;/b&gt;&lt;br/&gt;general capabilities, broad priors, model identity&lt;br/&gt;slow to update, globally shared, expensive to personalize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="220" y="208" width="920" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="b1-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D4ED8;strokeColor=#1D4ED8;strokeWidth=1;" vertex="1" parent="1">
                    <mxGeometry x="222" y="210" width="916" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b2" value="&lt;b&gt;Layer 2. Live state / active horizon&lt;/b&gt;&lt;br/&gt;task plan, current hypotheses, local variables, recent tool outcomes&lt;br/&gt;bounded by quality-cost trade-offs, not by the ambition to remember everything" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="220" y="350" width="920" height="132" as="geometry"/>
                </mxCell>
                <mxCell id="b2-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B45309;strokeColor=#B45309;strokeWidth=1;" vertex="1" parent="1">
                    <mxGeometry x="222" y="352" width="916" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b3" value="&lt;b&gt;Layer 3. External memory artifacts&lt;/b&gt;&lt;br/&gt;notes, AGENTS.md, memories, plans, retrieval indexes, structured summaries&lt;br/&gt;versionable, inspectable, shareable, and cheaper to persist than raw token history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="220" y="528" width="920" height="132" as="geometry"/>
                </mxCell>
                <mxCell id="b3-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F766E;strokeColor=#0F766E;strokeWidth=1;" vertex="1" parent="1">
                    <mxGeometry x="222" y="530" width="916" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b4" value="&lt;b&gt;Layer 4. Tools and environment&lt;/b&gt;&lt;br/&gt;repo state, databases, browsers, APIs, observability, real-world systems&lt;br/&gt;final truth source when the model must verify instead of merely remember" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#CBD5E1;strokeWidth=1.5;fontColor=#0F172A;fontSize=16;spacingTop=12;spacingLeft=18;spacingRight=18;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="220" y="706" width="920" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="b4-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#7C3AED;strokeWidth=1;" vertex="1" parent="1">
                    <mxGeometry x="222" y="708" width="916" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b5" value="&lt;b&gt;Token-preserving&lt;/b&gt;&lt;br/&gt;mindset&lt;br/&gt;keep as much&lt;br/&gt;history as&lt;br/&gt;possible" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#BE123C;strokeWidth=1.5;fontColor=#0F172A;fontSize=14;spacingTop=12;spacingLeft=18;spacingRight=18;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="68" y="384" width="124" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="b5-accent" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BE123C;strokeColor=#BE123C;strokeWidth=1;" vertex="1" parent="1">
                    <mxGeometry x="70" y="386" width="120" height="8" as="geometry"/>
                </mxCell>
                <mxCell id="b6" value="&lt;b&gt;State-preserving&lt;/b&gt;&lt;br/&gt;mindset&lt;br/&gt;retain only&lt;br/&gt;what must&lt;br/&gt;stay live" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDFA;strokeColor=#0F766E;strokeWidth=1.5;fontColor=#0F172A;fontSize=14;spacingTop=12;spacingLeft=18;spacingRight=18;align=center;verticalAlign=middle;" vertex="1" parent="1">
